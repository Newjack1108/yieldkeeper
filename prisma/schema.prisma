// YieldKeeper - Property Portfolio Management
// Prisma schema for Railway PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User (Lucia v3 + app attributes)
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  role         String    @default("portfolio_owner") // admin, portfolio_owner, manager, estate_agent, tenant
  createdAt    DateTime  @default(now())

  sessions           Session[]
  portfolios         Portfolio[]
  tenants            Tenant[]
  contractors        Contractor[]
  tenantActivityNotes TenantActivityNote[]
  estateAgent           EstateAgent?
  estateAgentsCreated   EstateAgent[] @relation("EstateAgentCreatedBy")
  landlordCompanies   LandlordCompany[]
  lettingAgents        LettingAgent[]
  tenantsWithLogin     Tenant[]         @relation("TenantLogin")
  maintenanceQuotedBy  MaintenanceRequest[] @relation("MaintenanceQuotedBy")
}

// Lucia v3 session
model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Portfolio {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties Property[]
}

model EstateAgent {
  id               String   @id @default(cuid())
  userId           String   @unique
  createdByUserId  String
  name             String
  company          String?
  email            String
  phone            String?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy        User      @relation("EstateAgentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  properties       Property[]

  @@index([userId])
  @@index([createdByUserId])
}

model LandlordCompany {
  id                 String    @id @default(cuid())
  userId             String
  name               String
  registrationNumber String
  address            String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties Property[]

  @@index([userId])
}

model LettingAgent {
  id                  String    @id @default(cuid())
  userId              String
  name                String
  company             String?
  email               String?
  phone               String?
  setupFee            Decimal?  @db.Decimal(12, 2)
  managementFeeType   String?   // monthly, percentage
  managementFeeValue  Decimal?  @db.Decimal(12, 2)
  inventoryFee        Decimal?  @db.Decimal(12, 2)
  renewalFee          Decimal?  @db.Decimal(12, 2)
  notes               String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties Property[]

  @@index([userId])
}

model Property {
  id                 String    @id @default(cuid())
  portfolioId        String
  address            String
  purchasePrice      Decimal?  @db.Decimal(12, 2)
  purchaseDate       DateTime?
  currentValue       Decimal?  @db.Decimal(12, 2)
  propertyType       String?   // flat, house, HMO, etc.
  bedrooms           Int?
  notes              String?   @db.Text
  occupancyStatus    String?   @default("vacant") // occupied, vacant, partial
  estateAgentId        String?
  lettingAgentId       String?
  lettingAgentAssignedAt DateTime?
  ownershipType        String    @default("sole") // sole, limited_company
  landlordCompanyId    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  portfolio         Portfolio           @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  estateAgent       EstateAgent?        @relation(fields: [estateAgentId], references: [id], onDelete: SetNull)
  lettingAgent      LettingAgent?       @relation(fields: [lettingAgentId], references: [id], onDelete: SetNull)
  landlordCompany   LandlordCompany?    @relation(fields: [landlordCompanyId], references: [id], onDelete: SetNull)
  units             Unit[]
  mortgages         Mortgage[]
  insurancePolicies InsurancePolicy[]
  tenancies         Tenancy[]
  inspections       Inspection[]
  maintenanceItems  MaintenanceRequest[]
  maintenanceTasks  PropertyMaintenanceTask[]
  complianceRecords ComplianceRecord[]
  expenses          PropertyExpense[]
  documents         Document[]

  @@index([portfolioId])
  @@index([estateAgentId])
  @@index([lettingAgentId])
  @@index([landlordCompanyId])
}

model Unit {
  id         String  @id @default(cuid())
  propertyId String
  unitLabel  String  // e.g. "Flat 1"
  bedrooms   Int?
  notes      String? @db.Text

  property  Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenancies Tenancy[]

  @@index([propertyId])
}

model PropertyMaintenanceTask {
  id         String   @id @default(cuid())
  propertyId String
  taskType   String   // window_cleaning, grass_cutting, gutter_cleanout, patio_cleaning, fence_repair, other
  name       String
  price      Decimal  @db.Decimal(12, 2)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  maintenanceRequests MaintenanceRequest[]

  @@index([propertyId])
}

model Mortgage {
  id               String    @id @default(cuid())
  propertyId       String
  lender           String
  interestRate     Decimal?  @db.Decimal(5, 2)
  loanBalance      Decimal?  @db.Decimal(12, 2)
  paymentAmount    Decimal?  @db.Decimal(12, 2)
  paymentFrequency String?   // monthly, quarterly, etc.
  nextPaymentDate  DateTime?
  fixedRateEndDate DateTime?
  termEndDate      DateTime?
  notes            String?   @db.Text

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model InsurancePolicy {
  id            String    @id @default(cuid())
  propertyId    String
  provider      String
  policyNumber  String?
  premium       Decimal?  @db.Decimal(12, 2)
  renewalDate   DateTime?
  coverageNotes String?   @db.Text

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Tenant {
  id               String   @id @default(cuid())
  userId           String
  loginUserId      String?  @unique
  name             String
  email            String?
  phone            String?
  emergencyContact String?  @db.Text
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginUser     User?                @relation("TenantLogin", fields: [loginUserId], references: [id], onDelete: SetNull)
  tenancies     Tenancy[]
  smsLogs       SmsLog[]
  documents     Document[]
  activityNotes TenantActivityNote[]
  invites       TenantInvite[]

  @@index([userId])
  @@index([loginUserId])
}

model TenantInvite {
  id        String   @id @default(cuid())
  tenantId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
}

model Tenancy {
  id             String    @id @default(cuid())
  propertyId     String
  unitId         String?
  tenantId       String
  startDate      DateTime
  endDate        DateTime?
  rentAmount     Decimal   @db.Decimal(12, 2)
  rentFrequency  String    @default("monthly") // weekly, monthly
  depositAmount  Decimal?  @db.Decimal(12, 2)
  depositScheme  String?
  status         String    @default("active") // active, ending_soon, expired, vacant
  notes          String?   @db.Text

  property           Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit               Unit?                 @relation(fields: [unitId], references: [id])
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rentSchedules      RentSchedule[]
  rentPayments       RentPayment[]
  inspections        Inspection[]
  maintenanceItems   MaintenanceRequest[]
  occupants          TenancyOccupant[]
  inspectionPreChecklists InspectionPreChecklist[]
  quarterlyChecklists QuarterlyChecklist[]

  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
}

model QuarterlyChecklist {
  id          String    @id @default(cuid())
  tenancyId   String
  token       String    @unique
  expiresAt   DateTime
  sentAt      DateTime?
  completedAt DateTime?
  answers     Json?
  createdAt   DateTime  @default(now())

  tenancy Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  @@index([tenancyId])
  @@index([token])
}

model TenancyOccupant {
  id           String   @id @default(cuid())
  tenancyId    String
  name         String
  relationship String   // partner, spouse, sibling, parent, child, roommate, lodger, other
  phone        String?
  email        String?
  notes        String?  @db.Text

  tenancy Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  @@index([tenancyId])
}

model RentSchedule {
  id        String   @id @default(cuid())
  tenancyId String
  dueDate   DateTime
  amountDue Decimal  @db.Decimal(12, 2)
  status    String   @default("pending") // pending, paid, partial, overdue

  tenancy      Tenancy        @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  rentPayments RentPayment[]

  @@index([tenancyId])
  @@index([dueDate, status])
}

model RentPayment {
  id             String   @id @default(cuid())
  tenancyId      String
  rentScheduleId String?
  amount         Decimal  @db.Decimal(12, 2)
  paidDate       DateTime
  method         String?
  notes          String?  @db.Text

  tenancy      Tenancy       @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  rentSchedule RentSchedule? @relation(fields: [rentScheduleId], references: [id])

  @@index([tenancyId])
}

model Inspection {
  id                    String    @id @default(cuid())
  propertyId            String
  tenancyId             String?
  type                  String    // landlord, self
  scheduledDate         DateTime?
  completedDate         DateTime?
  inspector             String?
  nextDueDate           DateTime?
  overallRating         Int?      // 1-5
  status                String?   // scheduled, completed, cancelled, pending_prechecklist
  preChecklistToken     String?   @unique
  preChecklistExpiresAt DateTime?

  property    Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenancy     Tenancy?              @relation(fields: [tenancyId], references: [id])
  items       InspectionItem[]
  photos      InspectionPhoto[]
  actions     InspectionAction[]
  preChecklist InspectionPreChecklist?

  @@index([propertyId])
}

model InspectionItem {
  id              String   @id @default(cuid())
  inspectionId    String
  roomName        String
  conditionRating Int?    // 1-5
  notes           String? @db.Text

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  photos     InspectionPhoto[]

  @@index([inspectionId])
}

model InspectionPhoto {
  id               String  @id @default(cuid())
  inspectionId     String
  inspectionItemId String?
  url              String
  caption          String?

  inspection     Inspection      @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  inspectionItem InspectionItem? @relation(fields: [inspectionItemId], references: [id])

  @@index([inspectionId])
}

model InspectionAction {
  id            String    @id @default(cuid())
  inspectionId  String
  description   String    @db.Text
  dueDate       DateTime?
  completedDate DateTime?
  status        String?   // pending, completed

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
}

model InspectionPreChecklist {
  id           String   @id @default(cuid())
  inspectionId String   @unique
  tenancyId    String
  completedAt  DateTime @default(now())
  answers      Json

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  tenancy    Tenancy    @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@index([tenancyId])
}

model Contractor {
  id           String   @id @default(cuid())
  userId       String
  name         String
  tradeType    String?  // plumber, electrician, etc.
  phone        String?
  email        String?
  coverageArea String?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  maintenanceRequests MaintenanceRequest[]

  @@index([userId])
}

model MaintenanceRequest {
  id                       String    @id @default(cuid())
  propertyId               String
  tenancyId                String?
  contractorId             String?
  propertyMaintenanceTaskId String?
  title                    String
  description              String?   @db.Text
  priority                 String    @default("medium") // low, medium, urgent, emergency
  status                   String    @default("reported") // reported, assigned, quoted, approved, in_progress, completed
  estimatedCost            Decimal?  @db.Decimal(12, 2)
  actualCost               Decimal?  @db.Decimal(12, 2)
  quotedAmount             Decimal?  @db.Decimal(12, 2)
  quotedAt                 DateTime?
  quotedById               String?
  paymentStatus            String    @default("none") // none, pending, paid, failed
  stripePaymentIntentId    String?
  tenantPaidAmount         Decimal?  @db.Decimal(12, 2)
  reportedDate             DateTime  @default(now())
  completedDate            DateTime?
  invoiceUrl               String?

  property                 Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenancy                  Tenancy?   @relation(fields: [tenancyId], references: [id])
  contractor               Contractor? @relation(fields: [contractorId], references: [id])
  propertyMaintenanceTask  PropertyMaintenanceTask? @relation(fields: [propertyMaintenanceTaskId], references: [id], onDelete: SetNull)
  quotedBy                 User?      @relation("MaintenanceQuotedBy", fields: [quotedById], references: [id], onDelete: SetNull)
  expenses                 PropertyExpense[]
  documents                Document[]

  @@index([propertyId])
  @@index([contractorId])
  @@index([status])
  @@index([propertyMaintenanceTaskId])
}

model PropertyExpense {
  id                   String    @id @default(cuid())
  propertyId            String
  maintenanceRequestId String?
  category             String    // mortgage, insurance, maintenance, compliance, management_fees, utilities, improvements, other
  amount               Decimal   @db.Decimal(12, 2)
  date                 DateTime
  description          String?   @db.Text
  invoiceUrl           String?

  property           Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])

  @@index([propertyId])
  @@index([date])
}

model ComplianceRecord {
  id               String    @id @default(cuid())
  propertyId       String
  type             String    // gas_safety, eicr, epc, smoke_alarm, hmo_license, insurance, other
  issueDate        DateTime?
  expiryDate       DateTime
  certificateNumber String?
  documentUrl      String?
  notes            String?   @db.Text

  property  Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([propertyId])
  @@index([expiryDate])
}

model Document {
  id                   String   @id @default(cuid())
  propertyId           String?
  tenantId             String?
  tenancyId            String?
  maintenanceRequestId String?
  complianceRecordId   String?
  type                 String   // tenancy_agreement, certificate, invoice, insurance, mortgage, inspection_photo, fault_photo, other
  filename             String
  url                  String
  mimeType             String?
  size                 Int?
  uploadedAt           DateTime @default(now())
  userId               String?

  property           Property?           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])
  complianceRecord   ComplianceRecord?  @relation(fields: [complianceRecordId], references: [id])

  @@index([propertyId])
  @@index([tenantId])
  @@index([maintenanceRequestId])
}

model SmsLog {
  id         String   @id @default(cuid())
  tenantId   String?
  propertyId String?
  toPhone    String
  messageType String  // rent_reminder, overdue_alert, inspection_request, maintenance_ack, maintenance_complete, custom
  direction  String   // outbound, inbound
  twilioSid  String?
  body       String   @db.Text
  status     String?
  sentAt     DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([sentAt])
}

model SmsTemplate {
  id       String  @id @default(cuid())
  type     String  @unique
  content  String  @db.Text
  isActive Boolean @default(true)
}

model TenantActivityNote {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  content   String   @db.Text
  type      String?  // call, meeting, note, email
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
